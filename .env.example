# Stream server URL (client-side, used by EventSource for SSE)
NEXT_PUBLIC_STREAM_URL=http://localhost:8002

# Ingest server URL (client-side, used by tablet sample UI)
NEXT_PUBLIC_INGEST_URL=http://localhost:8001

# Node environment
# NODE_ENV=production
